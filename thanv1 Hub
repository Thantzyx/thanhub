local steps = {
	{pct=12,  msg="Initializing environment..."},
	{pct=28,  msg="Connecting to server..."},
	{pct=46,  msg="Loading assets..."},
	{pct=63,  msg="Building GUI..."},
	{pct=78,  msg="Applying configurations..."},
	{pct=91,  msg="Almost ready..."},
	{pct=100, msg="Complete!"},
}

task.spawn(function()
	for _, step in ipairs(steps) do
		task.wait(math.random(45,70)/100)
		TweenService:Create(loadStatus, TweenInfo.new(0.2), {TextTransparency=1}):Play()
		task.wait(0.2)
		loadStatus.Text = step.msg
		TweenService:Create(loadStatus, TweenInfo.new(0.2), {TextTransparency=0}):Play()
		loadPct.Text = step.pct.."%"
		TweenService:Create(barFill, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{Size = UDim2.new(step.pct/100,0,1,0)}):Play()
	end
	task.wait(0.5)
	spinConn:Disconnect()
	TweenService:Create(barFill, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255,255,255)}):Play()
	task.wait(0.25)
	TweenService:Create(loadPanel, TweenInfo.new(0.38, Enum.EasingStyle.Back, Enum.EasingDirection.In),
		{Size = UDim2.new(0,0,0,0), Position = UDim2.new(0.5,0,0.5,0)}):Play()
	task.wait(0.42)
	loadPanel:Destroy()
	mainPanel.Size = UDim2.new(0,0,0,0)
	mainPanel.Position = UDim2.new(0.5,0,0.5,0)
	mainPanel.Visible = true
	TweenService:Create(mainPanel, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
		{Size = UDim2.new(0,panelW,0,panelH), Position = UDim2.new(0.5,-panelW/2,0.5,-panelH/2)}):Play()
end)
