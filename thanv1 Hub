local function spawnDots(parent, count)
	for i = 1, count do
		local dot = Instance.new("Frame")
		dot.Size = UDim2.new(0, math.random(2,4), 0, math.random(2,4))
		dot.Position = UDim2.new(math.random(), 0, math.random(), 0)
		dot.BackgroundColor3 = Color3.fromRGB(255,255,255)
		dot.BackgroundTransparency = math.random(55,80)/100
		dot.BorderSizePixel = 0
		dot.ZIndex = 2
		dot.Parent = parent
		local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(1,0); c.Parent = dot
		task.delay(math.random()*2, function()
			TweenService:Create(dot, TweenInfo.new(math.random(15,35)/10, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
				{BackgroundTransparency = math.random(10,35)/100}):Play()
		end)
	end
end

local function makePanel(w, h)
	local f = Instance.new("Frame")
	f.Size = UDim2.new(0,w,0,h)
	f.Position = UDim2.new(0.5,-w/2,0.5,-h/2)
	f.BackgroundColor3 = Color3.fromRGB(14,14,18)
	f.BackgroundTransparency = 0.05
	f.BorderSizePixel = 0
	f.ZIndex = 3
	f.Parent = screenGui
	local co = Instance.new("UICorner"); co.CornerRadius = UDim.new(0,20); co.Parent = f
	local st = Instance.new("UIStroke"); st.Color = Color3.fromRGB(55,55,62); st.Thickness = 1; st.Transparency = 0.35; st.Parent = f
	return f
end

